---
import { path } from '../lib/paths';
import { siteConfig } from '../data/site';
interface Props {
  current?: 'home' | 'notes' | 'projects' | 'about' | 'admin' | 'login';
}
const { current = 'home' } = Astro.props;
const items = [
  { id: 'home', href: path('/'), label: '首页' },
  { id: 'notes', href: path('/notes'), label: '笔记' },
  { id: 'projects', href: path('/projects'), label: '项目' },
  { id: 'about', href: path('/about'), label: '关于' },
] as const;
const resumeHref = path(siteConfig.resumePath);
---

<header class="site-header" data-header>
  <div class="header-inner container">
    <a class="logo" href={path('/')}>
      <span class="logo-mark" aria-hidden="true">
        <svg viewBox="0 0 36 36" width="34" height="34" fill="none">
          <circle cx="18" cy="18" r="16.5" stroke="currentColor" stroke-width="1.2" opacity="0.35" />
          <circle cx="18" cy="18" r="12" fill="rgba(243,241,234,0.65)" />
          <text
            x="18"
            y="22.5"
            text-anchor="middle"
            font-family="Noto Serif SC, Songti SC, serif"
            font-size="14"
            font-weight="600"
            fill="currentColor">艺</text>
        </svg>
      </span>
      <span class="logo-text">赵海蓺</span>
    </a>

    <nav class="nav desktop-nav" aria-label="主导航">
      {
        items.map((item) => (
          <a href={item.href} class={current === item.id ? 'is-active' : undefined} aria-current={current === item.id ? 'page' : undefined}>
            {item.label}
          </a>
        ))
      }
      <a class="btn btn-dark btn-sm nav-cta" href={resumeHref} download="赵海蓺-简历.pdf">下载简历</a>
    </nav>

    <div class="header-right-mobile">
      <a class="btn btn-dark btn-sm resume-m" href={resumeHref} download="赵海蓺-简历.pdf">简历</a>
      <button class="menu-toggle" type="button" aria-label="打开菜单" aria-expanded="false" data-menu-toggle>
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <nav class="mobile-nav" aria-label="移动导航" data-mobile-nav hidden>
    {
      items.map((item) => (
        <a href={item.href} class={current === item.id ? 'is-active' : undefined}>
          {item.label}
        </a>
      ))
    }
    <a href={resumeHref} download="赵海蓺-简历.pdf">下载简历</a>
    <a href={path('/login')} data-auth-link>登录写笔记</a>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(16px) saturate(1.2);
    background: rgba(243, 241, 234, 0.78);
    border-bottom: 1px solid transparent;
  }
  .site-header.is-solid {
    border-bottom-color: var(--line);
  }
  .header-inner {
    height: var(--header-h);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 700;
    font-size: 17px;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .logo-mark {
    display: grid;
    place-items: center;
    color: #3d3a4a;
    width: 34px;
    height: 34px;
  }
  .logo-text {
    font-family: var(--font-serif);
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .nav {
    display: flex;
    align-items: center;
    gap: 4px;
    color: var(--muted);
    font-size: 14px;
    font-weight: 600;
  }
  .nav a {
    padding: 8px 13px;
    border-radius: 999px;
  }
  .nav a:hover {
    color: var(--ink);
    background: rgba(12, 11, 16, 0.04);
  }
  .nav a.is-active {
    color: var(--ink);
    background: rgba(12, 11, 16, 0.06);
  }
  .nav-cta {
    margin-left: 8px;
  }
  .header-right-mobile {
    display: none;
    align-items: center;
    gap: 8px;
  }
  .menu-toggle {
    width: 42px;
    height: 42px;
    border-radius: 12px;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.8);
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    cursor: pointer;
    display: flex;
  }
  .menu-toggle span {
    display: block;
    width: 16px;
    height: 2px;
    background: var(--ink);
    border-radius: 2px;
  }
  .mobile-nav {
    display: none;
    flex-direction: column;
    gap: 8px;
    padding: 12px 24px 20px;
    border-bottom: 1px solid var(--line);
    background: rgba(243, 241, 234, 0.96);
  }
  .mobile-nav a {
    padding: 12px 14px;
    border-radius: 12px;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.8);
    font-weight: 600;
    color: var(--ink-soft);
  }
  .mobile-nav a.is-active {
    color: var(--accent);
    border-color: rgba(91, 77, 255, 0.28);
    background: var(--accent-soft);
  }
  .mobile-nav.is-open {
    display: flex;
  }
  @media (max-width: 860px) {
    .desktop-nav {
      display: none;
    }
    .header-right-mobile {
      display: flex;
    }
  }
</style>

<script is:inline>
  (function () {
    function bindHeader() {
      var header = document.querySelector('[data-header]');
      var toggle = document.querySelector('[data-menu-toggle]');
      var mobile = document.querySelector('[data-mobile-nav]');
      if (!header || header.dataset.bound === '1') return;
      header.dataset.bound = '1';
      var onScroll = function () {
        header.classList.toggle('is-solid', window.scrollY > 8);
      };
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });
      if (toggle && mobile) {
        toggle.addEventListener('click', function () {
          var open = mobile.classList.toggle('is-open');
          mobile.hidden = !open;
          toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        });
      }
    }
    bindHeader();
    document.addEventListener('astro:page-load', function () {
      var header = document.querySelector('[data-header]');
      if (header) header.dataset.bound = '';
      bindHeader();
    });
  })();
</script>

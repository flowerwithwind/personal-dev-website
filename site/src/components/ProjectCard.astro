---
import type { Project } from '../data/projects';
import { getProjectPreviewUrl, getProjectServices, buildDeployUrl } from '../data/projects';
import { path } from '../lib/paths';

interface Props {
  project: Project;
}
const { project } = Astro.props;
const preview = getProjectPreviewUrl(project);
const services = getProjectServices(project);
const primary = services.find((s) => s.isPrimaryPreview) ?? services[0];
const endpoint =
  primary != null
    ? { port: primary.port, url: buildDeployUrl(primary.port, primary.path) }
    : null;
const toneClass = project.coverTone;
---

<article class:list={['project-card', toneClass]}>
  <div class="thumb">
    <div class="label">{project.coverTone === 'violet' ? 'AI AGENT' : project.coverTone === 'teal' ? 'DATA AI' : 'PLATFORM'}</div>
    <div class="title-cn">{project.shortTitle}</div>
  </div>
  <div class="body">
    <div class="row">
      <span class="live-dot"><i></i> Online</span>
      {project.tags.slice(0, 2).map((t) => <span class="tag">{t}</span>)}
    </div>
    <h3>{project.title}</h3>
    <p>{project.summary}</p>
    {
      endpoint && (
        <div class="endpoint">
          <span class="port">:{endpoint.port}</span>
          <span class="url">{endpoint.url}</span>
        </div>
      )
    }
    <div class="actions">
      <a
        class:list={['btn', 'btn-preview', 'btn-sm', toneClass]}
        href={preview}
        target="_blank"
        rel="noopener noreferrer"
      >
        预览项目
      </a>
      <a class="btn btn-light btn-sm" href={path(`/projects/${project.slug}`)}>查看详情</a>
    </div>
  </div>
</article>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    border-radius: 22px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(255, 255, 255, 0.8);
    box-shadow: var(--shadow-sm);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .project-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow);
  }
  .thumb {
    height: 132px;
    padding: 18px 20px;
    color: #fff;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .violet .thumb {
    background:
      radial-gradient(circle at 80% 20%, rgba(255, 255, 255, 0.2), transparent 40%),
      linear-gradient(135deg, #7c6fff, #4f46e5);
  }
  .teal .thumb {
    background:
      radial-gradient(circle at 80% 20%, rgba(255, 255, 255, 0.2), transparent 40%),
      linear-gradient(135deg, #2dd4bf, #0f766e);
  }
  .amber .thumb {
    background:
      radial-gradient(circle at 80% 20%, rgba(255, 255, 255, 0.2), transparent 40%),
      linear-gradient(135deg, #fbbf24, #ea580c);
  }
  .label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.04em;
    opacity: 0.92;
  }
  .title-cn {
    font-family: var(--font-serif);
    font-size: 26px;
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .body {
    padding: 18px 20px 20px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 10px;
  }
  h3 {
    margin: 0 0 8px;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  p {
    color: var(--muted);
    font-size: 14px;
    font-weight: 500;
    line-height: 1.65;
    margin: 0 0 12px;
    flex: 1;
  }
  .endpoint {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11.5px;
    color: var(--ink-soft);
    background: rgba(12, 11, 16, 0.04);
    border-radius: 10px;
    padding: 8px 10px;
    margin-bottom: 14px;
    overflow: hidden;
  }
  .port {
    flex: 0 0 auto;
    color: var(--accent);
    font-weight: 600;
    background: var(--accent-soft);
    border-radius: 6px;
    padding: 2px 6px;
  }
  .url {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
</style>

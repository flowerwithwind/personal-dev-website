---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/site';
import { path } from '../lib/paths';

const timeline = [
  {
    period: '2026',
    title: 'Code Review Agent / 智能问数',
    org: '个人项目 · 写作同步公开',
    bullets: ['把评审与 NL2SQL 做成可部署系统，并写成系列笔记。'],
  },
  {
    period: '2025 — 2026',
    title: 'XHAgentOS 团队协作',
    org: 'Agent 平台实践',
    bullets: ['参与会话、知识库、技能与工作流等模块建设。'],
  },
  {
    period: 'Education',
    title: '计算机相关专业',
    org: '学习与实践并行',
    bullets: ['关注软件工程、机器学习 / NLP 与系统实现。'],
  },
];

const skills = [
  { name: 'Languages', items: ['Python', 'TypeScript', 'SQL'] },
  { name: 'AI / Backend', items: ['Agent', 'RAG', 'FastAPI', 'LangChain'] },
  { name: 'Frontend', items: ['Vue 3', 'React', 'Vite'] },
  { name: 'Engineering', items: ['Docker', 'GitHub', 'Pytest', '日志/限流'] },
];
---

<BaseLayout current="about" title="关于" description={`关于${siteConfig.name}`}>
  <main class="container layout">
    <aside class="profile">
      <div class="avatar" aria-hidden="true">ZH</div>
      <h1 class="serif">{siteConfig.name}</h1>
      <p class="role">写笔记的构建者 · AI Systems</p>
      <div class="links">
        <a href={siteConfig.github} target="_blank" rel="noopener noreferrer"><span>GitHub</span><span>↗</span></a>
        <a href={`mailto:${siteConfig.email}`}><span>Email</span><span>↗</span></a>
        <a href={path('/rss.xml')}><span>RSS</span><span>↗</span></a>
      </div>
    </aside>

    <div>
      <section class="block">
        <h2 class="serif">你好</h2>
        <p>
          我关注大模型真正进入业务时会发生什么：上下文不够、工具不可靠、结果难验收、系统难部署。因此更愿意做完整链路——从检索与 Agent 编排，到 API、界面、日志与容器化。
        </p>
        <p>
          这个网站用来公开一部分思考与项目。它首先服务我自己的记录，其次欢迎同行交流；如果也对招聘有帮助，那是它的附加价值。
        </p>
      </section>

      <section class="block">
        <h2 class="serif">轨迹</h2>
        <div class="timeline">
          {
            timeline.map((item) => (
              <div class="t-item">
                <div class="period">{item.period}</div>
                <h3>{item.title}</h3>
                <div class="org">{item.org}</div>
                <ul>
                  {item.bullets.map((b) => (
                    <li>{b}</li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </section>

      <section class="block">
        <h2 class="serif">技能</h2>
        <div class="skills">
          {
            skills.map((g) => (
              <div class="skill">
                <h3>{g.name}</h3>
                <div class="tags">
                  {g.items.map((i) => (
                    <span class="tag">{i}</span>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </section>

      <section class="block actions">
        <a class="btn btn-dark" href={`mailto:${siteConfig.email}`}>邮件联系</a>
        <a class="btn btn-light" href={path('/notes')}>阅读笔记</a>
        <a class="btn btn-soft" href={path('/projects')}>查看项目</a>
      </section>
    </div>
  </main>
</BaseLayout>

<style>
  .layout {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 28px;
    padding: 40px 0 56px;
    align-items: start;
  }
  .profile {
    position: sticky;
    top: calc(var(--header-h) + 16px);
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(255, 255, 255, 0.8);
    border-radius: 24px;
    padding: 22px;
    box-shadow: var(--shadow);
    backdrop-filter: blur(10px);
  }
  .avatar {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 18px;
    margin-bottom: 16px;
    display: grid;
    place-items: center;
    font-family: var(--font-serif);
    font-size: 42px;
    font-weight: 700;
    color: #fff;
    background:
      radial-gradient(circle at 30% 25%, rgba(255, 255, 255, 0.28), transparent 40%),
      linear-gradient(145deg, #8b7cff, #5b4dff 50%, #14b8a6);
  }
  .profile h1 {
    font-size: 26px;
    font-weight: 600;
    margin: 0 0 4px;
  }
  .role {
    color: var(--muted);
    font-size: 14px;
    font-weight: 500;
    margin: 0 0 16px;
  }
  .links {
    display: grid;
    gap: 8px;
  }
  .links a {
    display: flex;
    justify-content: space-between;
    padding: 10px 12px;
    border-radius: 12px;
    border: 1px solid var(--line);
    background: rgba(243, 241, 234, 0.6);
    font-size: 13px;
    font-weight: 600;
    color: var(--ink-soft);
  }
  .block {
    margin-bottom: 32px;
  }
  .block h2 {
    font-size: 26px;
    font-weight: 600;
    margin: 0 0 12px;
  }
  .block p {
    color: var(--ink-soft);
    font-weight: 500;
    margin: 0 0 12px;
    max-width: 640px;
  }
  .timeline {
    border-left: 2px solid var(--line);
    margin-left: 8px;
    padding-left: 22px;
  }
  .t-item {
    position: relative;
    padding-bottom: 22px;
  }
  .t-item::before {
    content: '';
    position: absolute;
    left: -29px;
    top: 6px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #fff;
    border: 2px solid var(--accent);
    box-shadow: 0 0 0 4px var(--accent-soft);
  }
  .period {
    font-size: 12px;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 4px;
  }
  .t-item h3 {
    font-size: 17px;
    font-weight: 700;
    margin: 0 0 4px;
  }
  .org {
    color: var(--muted);
    font-size: 13.5px;
    font-weight: 500;
    margin-bottom: 8px;
  }
  .t-item ul {
    margin: 0;
    padding-left: 16px;
    color: var(--ink-soft);
    font-size: 14px;
    font-weight: 500;
  }
  .skills {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .skill {
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: 16px;
  }
  .skill h3 {
    font-size: 13px;
    color: var(--accent);
    font-weight: 700;
    margin: 0 0 10px;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  @media (max-width: 860px) {
    .layout,
    .skills {
      grid-template-columns: 1fr;
    }
    .profile {
      position: static;
    }
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import { path } from '../lib/paths';
---

<BaseLayout current="admin" title="写笔记" description="作者笔记编辑台">
  <div
    class="container wrap"
    data-animate="fade-up"
    id="admin-root"
    data-login-path={path('/login')}
    data-local-base={path('/notes/local')}
  >
    <div class="gate card" id="admin-gate">
      <p>正在校验登录状态…</p>
    </div>

    <div class="panel" id="admin-panel" hidden>
      <header class="head">
        <div>
          <p class="eyebrow">Admin · 已登录</p>
          <h1 class="serif">写一篇笔记</h1>
          <p class="sub">
            笔记优先写入本机 <strong>IndexedDB</strong>（容量更大、更稳）；可导出 Markdown 纳入仓库做全站永久发布。
          </p>
        </div>
        <div class="head-actions">
          <a class="btn btn-light btn-sm" href={path('/notes')}>查看笔记列表</a>
          <button type="button" class="btn btn-soft btn-sm" id="admin-logout">退出登录</button>
        </div>
      </header>

      <form class="editor card" id="note-form">
        <label>
          <span>标题</span>
          <input name="title" required maxlength="120" placeholder="例如：本周关于 RAG 的三处思考" />
        </label>
        <label>
          <span>摘要</span>
          <input name="summary" required maxlength="200" placeholder="一句话说明这篇笔记在讲什么" />
        </label>
        <div class="row">
          <label>
            <span>分类标签</span>
            <select name="categoryLabel">
              <option>Essay · Agent</option>
              <option>Note · RAG</option>
              <option>Journal</option>
              <option>Reading</option>
              <option>Garden · Seed</option>
              <option selected>随笔</option>
            </select>
          </label>
          <label>
            <span>状态</span>
            <select name="status">
              <option value="published">已发布</option>
              <option value="growing">生长中</option>
            </select>
          </label>
        </div>
        <label>
          <span>标签（逗号分隔）</span>
          <input name="tags" placeholder="Agent, 工程, 随笔" />
        </label>
        <label>
          <span>正文（支持 Markdown）</span>
          <textarea name="body" required rows="14" placeholder="写点什么…"></textarea>
        </label>
        <div class="actions">
          <button class="btn btn-dark" type="submit">保存笔记</button>
          <button class="btn btn-light" type="button" id="export-md">导出 Markdown</button>
        </div>
        <p class="ok" id="save-ok" hidden>已保存到本机。打开「笔记」列表即可看到。</p>
        <p class="err" id="save-err" hidden></p>
      </form>

      <section class="list card">
        <h2 class="serif">本机已存笔记</h2>
        <ul id="user-note-list" data-animate-stagger></ul>
      </section>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  (function () {
    var AUTH_KEY = 'personal-site-auth-v1';
    var LS_KEY = 'personal-site-user-notes-v1';
    var DB_NAME = 'personal-site-notes-db';
    var STORE = 'notes';

    function readSession() {
      try {
        var raw = sessionStorage.getItem(AUTH_KEY);
        if (!raw) return null;
        var parsed = JSON.parse(raw);
        if (!parsed || !parsed.ok || typeof parsed.at !== 'number') return null;
        if (Date.now() - parsed.at > 12 * 3600 * 1000) {
          sessionStorage.removeItem(AUTH_KEY);
          return null;
        }
        return parsed;
      } catch (e) {
        return null;
      }
    }

    function openDb() {
      return new Promise(function (resolve, reject) {
        if (!window.indexedDB) {
          reject(new Error('no idb'));
          return;
        }
        var req = indexedDB.open(DB_NAME, 1);
        req.onupgradeneeded = function () {
          var db = req.result;
          if (!db.objectStoreNames.contains(STORE)) db.createObjectStore(STORE, { keyPath: 'slug' });
        };
        req.onsuccess = function () {
          resolve(req.result);
        };
        req.onerror = function () {
          reject(req.error);
        };
      });
    }

    function idbGetAll() {
      return openDb().then(function (db) {
        return new Promise(function (resolve, reject) {
          var tx = db.transaction(STORE, 'readonly');
          var req = tx.objectStore(STORE).getAll();
          req.onsuccess = function () {
            resolve(req.result || []);
          };
          req.onerror = function () {
            reject(req.error);
          };
        });
      });
    }

    function idbPut(note) {
      return openDb().then(function (db) {
        return new Promise(function (resolve, reject) {
          var tx = db.transaction(STORE, 'readwrite');
          tx.objectStore(STORE).put(note);
          tx.oncomplete = function () {
            resolve();
          };
          tx.onerror = function () {
            reject(tx.error);
          };
        });
      });
    }

    function lsRead() {
      try {
        var raw = localStorage.getItem(LS_KEY);
        return raw ? JSON.parse(raw) : [];
      } catch (e) {
        return [];
      }
    }

    function lsWrite(list) {
      localStorage.setItem(LS_KEY, JSON.stringify(list));
    }

    async function readNotes() {
      try {
        var list = await idbGetAll();
        if (list.length) return list;
        var ls = lsRead();
        for (var i = 0; i < ls.length; i++) await idbPut(ls[i]);
        return ls;
      } catch (e) {
        return lsRead();
      }
    }

    async function upsert(note) {
      try {
        await idbPut(note);
        var all = await idbGetAll();
        lsWrite(all);
        return all;
      } catch (e) {
        var all2 = lsRead().filter(function (n) {
          return n.slug !== note.slug;
        });
        all2.unshift(note);
        lsWrite(all2);
        return all2;
      }
    }

    function slugify(title) {
      var base = title
        .trim()
        .toLowerCase()
        .replace(/[\s_]+/g, '-')
        .replace(/[^\w\u4e00-\u9fff-]+/g, '')
        .replace(/-+/g, '-')
        .replace(/^-|-$/g, '');
      return (base || 'note') + '-' + Date.now().toString(36).slice(-4);
    }

    function escapeHtml(s) {
      return String(s).replace(/[&<>"']/g, function (c) {
        return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
      });
    }

    function boot() {
      var root = document.getElementById('admin-root');
      if (!root || root.dataset.bound === '1') return;
      root.dataset.bound = '1';

      var loginPath = root.getAttribute('data-login-path') || '/login';
      var localBase = root.getAttribute('data-local-base') || '/notes/local/';
      var gate = document.getElementById('admin-gate');
      var panel = document.getElementById('admin-panel');
      var form = document.getElementById('note-form');
      var listEl = document.getElementById('user-note-list');
      var ok = document.getElementById('save-ok');
      var err = document.getElementById('save-err');

      if (!readSession()) {
        location.replace(loginPath);
        return;
      }
      if (gate) gate.hidden = true;
      if (panel) panel.hidden = false;

      async function renderList() {
        if (!listEl) return;
        var notes = await readNotes();
        if (!notes.length) {
          listEl.innerHTML = '<li class="empty">还没有本机笔记。</li>';
          return;
        }
        listEl.innerHTML = notes
          .map(function (n) {
            return (
              '<li><a href="' +
              localBase +
              '?slug=' +
              encodeURIComponent(n.slug) +
              '"><strong>' +
              escapeHtml(n.title) +
              '</strong><span>' +
              escapeHtml(n.publishedAt) +
              '</span></a></li>'
            );
          })
          .join('');
      }

      function formToNote(fd) {
        var title = String(fd.get('title') || '').trim();
        var tags = String(fd.get('tags') || '')
          .split(/[,，]/)
          .map(function (t) {
            return t.trim();
          })
          .filter(Boolean);
        var body = String(fd.get('body') || '');
        var words = body.replace(/\s+/g, '').length;
        return {
          slug: slugify(title),
          title: title,
          summary: String(fd.get('summary') || '').trim(),
          categoryLabel: String(fd.get('categoryLabel') || '随笔'),
          tags: tags,
          filters: tags.length ? tags : ['随笔'],
          publishedAt: new Date().toISOString().slice(0, 10),
          readingMinutes: Math.max(1, Math.round(words / 400)),
          status: String(fd.get('status') || 'published'),
          body: body,
          source: 'user',
          updatedAt: new Date().toISOString(),
        };
      }

      if (form) {
        form.addEventListener('submit', async function (e) {
          e.preventDefault();
          if (ok) ok.hidden = true;
          if (err) err.hidden = true;
          try {
            var note = formToNote(new FormData(form));
            await upsert(note);
            if (ok) ok.hidden = false;
            form.reset();
            await renderList();
          } catch (ex) {
            if (err) {
              err.hidden = false;
              err.textContent = (ex && ex.message) || '保存失败';
            }
          }
        });
      }

      var exportBtn = document.getElementById('export-md');
      if (exportBtn && form) {
        exportBtn.addEventListener('click', function () {
          var note = formToNote(new FormData(form));
          var md =
            '---\ntitle: ' +
            note.title +
            '\nslug: ' +
            note.slug +
            '\ndate: ' +
            note.publishedAt +
            '\ntags: [' +
            note.tags.join(', ') +
            ']\n---\n\n' +
            note.body +
            '\n';
          var blob = new Blob([md], { type: 'text/markdown;charset=utf-8' });
          var a = document.createElement('a');
          a.href = URL.createObjectURL(blob);
          a.download = note.slug + '.md';
          a.click();
          URL.revokeObjectURL(a.href);
        });
      }

      var logout = document.getElementById('admin-logout');
      if (logout) {
        logout.addEventListener('click', function () {
          sessionStorage.removeItem(AUTH_KEY);
          location.href = loginPath;
        });
      }

      renderList();
    }

    boot();
    document.addEventListener('astro:page-load', boot);
  })();
</script>

<style>
  .wrap {
    padding: 40px 0 64px;
  }
  .gate,
  .card {
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(255, 255, 255, 0.85);
    border-radius: 22px;
    box-shadow: var(--shadow-sm);
    backdrop-filter: blur(10px);
  }
  .gate {
    padding: 28px;
    text-align: center;
    color: var(--muted);
  }
  .head {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    align-items: start;
    margin-bottom: 18px;
  }
  .eyebrow {
    margin: 0 0 6px;
    font-size: 12px;
    font-weight: 700;
    color: var(--accent-2);
    letter-spacing: 0.04em;
  }
  h1 {
    margin: 0 0 8px;
    font-size: 32px;
    font-weight: 600;
  }
  .sub {
    margin: 0;
    color: var(--muted);
    font-size: 14px;
    font-weight: 500;
    max-width: 560px;
  }
  .head-actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .editor {
    padding: 22px;
    display: grid;
    gap: 14px;
    margin-bottom: 16px;
  }
  label {
    display: grid;
    gap: 7px;
    font-size: 13px;
    font-weight: 600;
    color: var(--ink-soft);
  }
  input,
  select,
  textarea {
    border-radius: 12px;
    border: 1px solid var(--line-strong);
    background: #fff;
    padding: 11px 12px;
    font: inherit;
  }
  textarea {
    resize: vertical;
    min-height: 220px;
    line-height: 1.65;
  }
  .row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .ok {
    margin: 0;
    color: #0f766e;
    font-size: 13.5px;
    font-weight: 600;
  }
  .err {
    margin: 0;
    color: #b42318;
    font-size: 13.5px;
    font-weight: 600;
  }
  .list {
    padding: 20px 22px;
  }
  .list h2 {
    margin: 0 0 12px;
    font-size: 20px;
    font-weight: 600;
  }
  .list ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 8px;
  }
  .list li a {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    padding: 12px 14px;
    border-radius: 12px;
    border: 1px solid var(--line);
    background: rgba(243, 241, 234, 0.5);
    font-size: 14px;
  }
  .list span {
    color: var(--muted);
    font-size: 12px;
    font-weight: 600;
    white-space: nowrap;
  }
  .empty {
    color: var(--muted);
    font-size: 14px;
  }
  @media (max-width: 640px) {
    .row {
      grid-template-columns: 1fr;
    }
  }
</style>

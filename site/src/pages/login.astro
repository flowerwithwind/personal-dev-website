---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/site';
import { path } from '../lib/paths';
const expectedHash = siteConfig.adminPasswordSha256;
const adminPath = path('/admin');
const homePath = path('/');
---

<BaseLayout current="login" title="登录" description="作者登录后可添加笔记">
  <div class="container wrap" data-animate="fade-up">
    <div class="card">
      <p class="kicker"><i></i> 作者入口</p>
      <h1 class="serif">登录后写笔记</h1>
      <p class="lead">
        仅站主可发布笔记。验证通过后会在本机浏览器保持登录一段时间，然后进入写笔记面板。
      </p>

      <form class="form" id="login-form" data-expected-hash={expectedHash} data-admin-path={adminPath}>
        <label>
          <span>密码</span>
          <input
            type="password"
            name="password"
            id="login-password"
            autocomplete="current-password"
            required
            placeholder="输入作者密码"
          />
        </label>
        <p class="err" id="login-error" hidden></p>
        <button class="btn btn-dark" type="submit" id="login-submit">登录</button>
      </form>

      <p class="hint">
        默认演示密码：<code>haiyi2026</code>。修改请更新
        <code>siteConfig.adminPasswordSha256</code>。
        笔记默认存 IndexedDB（本机），可导出 Markdown。
      </p>
      <a class="back" href={homePath}>← 返回首页</a>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  (function () {
    function boot() {
      var form = document.getElementById('login-form');
      if (!form || form.dataset.bound === '1') return;
      form.dataset.bound = '1';

      var expectedHash = (form.getAttribute('data-expected-hash') || '').trim().toLowerCase();
      var adminPath = form.getAttribute('data-admin-path') || '/admin';
      var err = document.getElementById('login-error');
      var AUTH_KEY = 'personal-site-auth-v1';

      function showError(msg) {
        if (!err) return;
        err.hidden = false;
        err.textContent = msg;
      }

      function readSession() {
        try {
          var raw = sessionStorage.getItem(AUTH_KEY);
          if (!raw) return null;
          var parsed = JSON.parse(raw);
          if (!parsed || !parsed.ok || typeof parsed.at !== 'number') return null;
          if (Date.now() - parsed.at > 12 * 3600 * 1000) {
            sessionStorage.removeItem(AUTH_KEY);
            return null;
          }
          return parsed;
        } catch (e) {
          return null;
        }
      }

      if (readSession()) {
        location.replace(adminPath);
        return;
      }

      async function sha256Hex(text) {
        if (!window.crypto || !window.crypto.subtle) {
          throw new Error('当前浏览器不支持安全登录（请使用 HTTPS 或 localhost）');
        }
        var data = new TextEncoder().encode(text);
        var buf = await crypto.subtle.digest('SHA-256', data);
        return Array.from(new Uint8Array(buf))
          .map(function (b) {
            return b.toString(16).padStart(2, '0');
          })
          .join('');
      }

      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        if (err) err.hidden = true;
        var input = document.getElementById('login-password');
        var password = (input && input.value ? input.value : '').trim();
        if (!password) {
          showError('请输入密码');
          return;
        }
        try {
          var got = await sha256Hex(password);
          if (got !== expectedHash) {
            showError('密码不正确，请重试。');
            return;
          }
          sessionStorage.setItem(AUTH_KEY, JSON.stringify({ ok: true, at: Date.now() }));
          location.href = adminPath;
        } catch (ex) {
          showError(ex && ex.message ? ex.message : '登录失败，请重试');
        }
      });
    }

    boot();
    document.addEventListener('astro:page-load', boot);
  })();
</script>

<style>
  .wrap {
    padding: 56px 0 72px;
    display: grid;
    place-items: center;
  }
  .card {
    width: min(100%, 440px);
    padding: 32px 28px;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(255, 255, 255, 0.85);
    box-shadow: var(--shadow);
    backdrop-filter: blur(12px);
  }
  .kicker {
    margin: 0 0 14px;
  }
  h1 {
    margin: 0 0 10px;
    font-size: 30px;
    font-weight: 600;
  }
  .lead {
    margin: 0 0 22px;
    color: var(--muted);
    font-size: 14.5px;
    font-weight: 500;
  }
  .form {
    display: grid;
    gap: 14px;
  }
  label {
    display: grid;
    gap: 8px;
    font-size: 13px;
    font-weight: 600;
    color: var(--ink-soft);
  }
  input {
    min-height: 46px;
    border-radius: 12px;
    border: 1px solid var(--line-strong);
    background: #fff;
    padding: 0 14px;
  }
  input:focus {
    outline: none;
    box-shadow: var(--focus);
    border-color: rgba(91, 77, 255, 0.35);
  }
  .err {
    margin: 0;
    color: #b42318;
    font-size: 13px;
    font-weight: 600;
  }
  .hint {
    margin: 18px 0 12px;
    font-size: 12.5px;
    color: var(--muted);
    line-height: 1.6;
  }
  .hint code {
    font-family: var(--font-mono);
    font-size: 11px;
    background: rgba(12, 11, 16, 0.05);
    padding: 1px 5px;
    border-radius: 4px;
  }
  .back {
    color: var(--accent);
    font-size: 13.5px;
    font-weight: 700;
  }
</style>

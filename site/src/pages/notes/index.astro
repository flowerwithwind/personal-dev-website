---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllNotes, getNoteFilterChips } from '../../data/notes';
import { formatDate } from '../../lib/format';
import { path } from '../../lib/paths';

const notes = getAllNotes();
const chips = getNoteFilterChips();
---

<BaseLayout current="notes" title="笔记" description="公开的思考与实验记录 · Digital Garden">
  <div class="container page">
    <header class="page-hero">
      <div class="hero-row">
        <div>
          <h1 class="serif">笔记</h1>
          <p>
            公开的思考与实验记录。有些是完整文章，有些仍会继续修改——更接近 digital garden，而不是新闻博客。
          </p>
        </div>
        <a class="btn btn-dark btn-sm write-btn" href={path('/login')} data-write-note-btn>写笔记</a>
      </div>
    </header>

    <div class="filters" role="toolbar" aria-label="笔记筛选" data-note-filters>
      {
        chips.map((chip, i) => (
          <button type="button" class:list={['chip', { 'is-active': i === 0 }]} data-filter={chip}>
            {chip}
          </button>
        ))
      }
    </div>

    <div class="list" data-note-list data-local-base={path('/notes/local/')} data-admin-path={path('/admin')} data-login-path={path('/login')}>
      {
        notes.map((note) => (
          <a
            class="item"
            href={path(`/notes/${note.slug}`)}
            data-tags={[...note.filters, ...note.tags, note.categoryLabel].join('|')}
          >
            <div>
              <div class:list={['cat', { seed: note.status === 'growing' }]}>{note.categoryLabel}</div>
              <h2 class="serif">{note.title}</h2>
              <p>{note.summary}</p>
            </div>
            <div class="date">{note.status === 'growing' ? '持续更新' : formatDate(note.publishedAt)}</div>
          </a>
        ))
      }
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    padding-bottom: 56px;
  }
  .page-hero {
    padding: 48px 0 18px;
  }
  .hero-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    flex-wrap: wrap;
  }
  .page-hero h1 {
    font-size: 44px;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0 0 10px;
  }
  .page-hero p {
    margin: 0;
    color: var(--muted);
    font-weight: 500;
    max-width: 560px;
  }
  .write-btn {
    flex: 0 0 auto;
  }
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 8px 0 22px;
  }
  .list {
    display: grid;
    gap: 12px;
    max-width: 900px;
  }
  .item {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 16px;
    padding: 18px 20px;
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(255, 255, 255, 0.75);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .item:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow);
  }
  .cat {
    font-size: 12px;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 6px;
  }
  .cat.seed {
    color: #b45309;
  }
  h2 {
    font-size: 20px;
    font-weight: 600;
    letter-spacing: -0.015em;
    margin: 0 0 8px;
  }
  p {
    margin: 0;
    color: var(--muted);
    font-size: 14px;
    font-weight: 500;
  }
  .date {
    font-size: 12px;
    font-weight: 600;
    color: rgba(12, 11, 16, 0.4);
    white-space: nowrap;
    padding-top: 2px;
  }
  @media (max-width: 640px) {
    .item {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  import { readSession, readUserNotes } from '../../lib/auth.ts';

  const toolbar = document.querySelector('[data-note-filters]');
  const list = document.querySelector<HTMLElement>('[data-note-list]');
  const writeBtn = document.querySelector<HTMLAnchorElement>('[data-write-note-btn]');
  const localBase = list?.dataset.localBase || '/notes/local/';
  const adminPath = list?.dataset.adminPath || '/admin';
  const loginPath = list?.dataset.loginPath || '/login';

  if (writeBtn) {
    writeBtn.href = readSession() ? adminPath : loginPath;
    writeBtn.textContent = readSession() ? '写笔记' : '登录写笔记';
  }

  if (list) {
    const userNotes = readUserNotes();
    userNotes.forEach((n) => {
      const a = document.createElement('a');
      a.className = 'item item-user';
      a.href = `${localBase}?slug=${encodeURIComponent(n.slug)}`;
      a.dataset.tags = [...n.filters, ...n.tags, n.categoryLabel, '本机'].join('|');
      a.innerHTML = `<div><div class="cat">本机 · ${escapeHtml(n.categoryLabel)}</div><h2 class="serif">${escapeHtml(n.title)}</h2><p>${escapeHtml(n.summary)}</p></div><div class="date">${n.status === 'growing' ? '持续更新' : n.publishedAt}</div>`;
      list.prepend(a);
    });
  }

  function escapeHtml(s: string) {
    return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c] as string);
  }

  if (toolbar && list) {
    toolbar.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-filter]');
      if (!btn) return;
      toolbar.querySelectorAll('.chip').forEach((c) => c.classList.remove('is-active'));
      btn.classList.add('is-active');
      const key = btn.dataset.filter || '全部';
      list.querySelectorAll<HTMLElement>('.item').forEach((item) => {
        const tags = item.dataset.tags || '';
        const show = key === '全部' || tags.split('|').some((t) => t.includes(key) || key.includes(t));
        item.style.display = show ? '' : 'none';
      });
    });
  }
</script>

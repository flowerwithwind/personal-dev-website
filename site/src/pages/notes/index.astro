---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllNotes, getNoteFilterChips } from '../../data/notes';
import { formatDate } from '../../lib/format';
import { path } from '../../lib/paths';

const notes = getAllNotes();
const chips = getNoteFilterChips();
---

<BaseLayout current="notes" title="笔记" description="公开的思考与实验记录 · Digital Garden">
  <div class="container page">
    <header class="page-hero" data-animate="fade-up">
      <div class="hero-row">
        <div>
          <h1 class="serif">笔记</h1>
          <p>
            公开的思考与实验记录。有些是完整文章，有些仍会继续修改——更接近 digital garden，而不是新闻博客。
          </p>
        </div>
        <a class="btn btn-dark btn-sm write-btn" href={path('/login')} id="write-note-btn">写笔记</a>
      </div>
    </header>

    <div class="filters" role="toolbar" aria-label="笔记筛选" id="note-filters" data-animate="fade-up">
      {
        chips.map((chip, i) => (
          <button type="button" class:list={['chip', { 'is-active': i === 0 }]} data-filter={chip}>
            {chip}
          </button>
        ))
      }
    </div>

    <div
      class="list"
      id="note-list"
      data-animate-stagger
      data-local-base={path('/notes/local/')}
      data-admin-path={path('/admin')}
      data-login-path={path('/login')}
    >
      {
        notes.map((note) => (
          <a
            class="item"
            href={path(`/notes/${note.slug}`)}
            data-tags={[...note.filters, ...note.tags, note.categoryLabel].join('|')}
          >
            <div>
              <div class:list={['cat', { seed: note.status === 'growing' }]}>{note.categoryLabel}</div>
              <h2 class="serif">{note.title}</h2>
              <p>{note.summary}</p>
            </div>
            <div class="date">{note.status === 'growing' ? '持续更新' : formatDate(note.publishedAt)}</div>
          </a>
        ))
      }
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    padding-bottom: 56px;
  }
  .page-hero {
    padding: 48px 0 18px;
  }
  .hero-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    flex-wrap: wrap;
  }
  .page-hero h1 {
    font-size: 44px;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0 0 10px;
  }
  .page-hero p {
    margin: 0;
    color: var(--muted);
    font-weight: 500;
    max-width: 560px;
  }
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 8px 0 22px;
  }
  .list {
    display: grid;
    gap: 12px;
    max-width: 900px;
  }
  .item {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 16px;
    padding: 18px 20px;
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(255, 255, 255, 0.75);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .item:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow);
  }
  .cat {
    font-size: 12px;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 6px;
  }
  .cat.seed {
    color: #b45309;
  }
  h2 {
    font-size: 20px;
    font-weight: 600;
    letter-spacing: -0.015em;
    margin: 0 0 8px;
  }
  p {
    margin: 0;
    color: var(--muted);
    font-size: 14px;
    font-weight: 500;
  }
  .date {
    font-size: 12px;
    font-weight: 600;
    color: rgba(12, 11, 16, 0.4);
    white-space: nowrap;
    padding-top: 2px;
  }
  @media (max-width: 640px) {
    .item {
      grid-template-columns: 1fr;
    }
  }
</style>

<script is:inline>
  (function () {
    var AUTH_KEY = 'personal-site-auth-v1';
    var LS_KEY = 'personal-site-user-notes-v1';
    var DB_NAME = 'personal-site-notes-db';
    var STORE = 'notes';

    function readSession() {
      try {
        var raw = sessionStorage.getItem(AUTH_KEY);
        if (!raw) return null;
        var parsed = JSON.parse(raw);
        if (!parsed || !parsed.ok) return null;
        if (Date.now() - parsed.at > 12 * 3600 * 1000) return null;
        return parsed;
      } catch (e) {
        return null;
      }
    }

    function openDb() {
      return new Promise(function (resolve, reject) {
        if (!window.indexedDB) return reject(new Error('no idb'));
        var req = indexedDB.open(DB_NAME, 1);
        req.onupgradeneeded = function () {
          var db = req.result;
          if (!db.objectStoreNames.contains(STORE)) db.createObjectStore(STORE, { keyPath: 'slug' });
        };
        req.onsuccess = function () {
          resolve(req.result);
        };
        req.onerror = function () {
          reject(req.error);
        };
      });
    }

    async function readNotes() {
      try {
        var db = await openDb();
        var list = await new Promise(function (resolve, reject) {
          var tx = db.transaction(STORE, 'readonly');
          var req = tx.objectStore(STORE).getAll();
          req.onsuccess = function () {
            resolve(req.result || []);
          };
          req.onerror = function () {
            reject(req.error);
          };
        });
        if (list.length) return list;
      } catch (e) {}
      try {
        var raw = localStorage.getItem(LS_KEY);
        return raw ? JSON.parse(raw) : [];
      } catch (e2) {
        return [];
      }
    }

    function escapeHtml(s) {
      return String(s).replace(/[&<>"']/g, function (c) {
        return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
      });
    }

    async function boot() {
      var list = document.getElementById('note-list');
      var writeBtn = document.getElementById('write-note-btn');
      var toolbar = document.getElementById('note-filters');
      if (!list) return;
      if (list.dataset.hydrated === '1') return;
      list.dataset.hydrated = '1';

      var localBase = list.getAttribute('data-local-base') || '/notes/local/';
      var adminPath = list.getAttribute('data-admin-path') || '/admin';
      var loginPath = list.getAttribute('data-login-path') || '/login';

      if (writeBtn) {
        if (readSession()) {
          writeBtn.href = adminPath;
          writeBtn.textContent = '写笔记';
        } else {
          writeBtn.href = loginPath;
          writeBtn.textContent = '登录写笔记';
        }
      }

      var userNotes = await readNotes();
      userNotes.forEach(function (n) {
        var a = document.createElement('a');
        a.className = 'item item-user';
        a.href = localBase + '?slug=' + encodeURIComponent(n.slug);
        a.dataset.tags = []
          .concat(n.filters || [], n.tags || [], [n.categoryLabel || '', '本机'])
          .join('|');
        a.innerHTML =
          '<div><div class="cat">本机 · ' +
          escapeHtml(n.categoryLabel || '随笔') +
          '</div><h2 class="serif">' +
          escapeHtml(n.title) +
          '</h2><p>' +
          escapeHtml(n.summary || '') +
          '</p></div><div class="date">' +
          (n.status === 'growing' ? '持续更新' : escapeHtml(n.publishedAt || '')) +
          '</div>';
        list.prepend(a);
      });

      if (toolbar) {
        toolbar.addEventListener('click', function (e) {
          var btn = e.target.closest('[data-filter]');
          if (!btn) return;
          toolbar.querySelectorAll('.chip').forEach(function (c) {
            c.classList.remove('is-active');
          });
          btn.classList.add('is-active');
          var key = btn.getAttribute('data-filter') || '全部';
          list.querySelectorAll('.item').forEach(function (item) {
            var tags = item.getAttribute('data-tags') || '';
            var show =
              key === '全部' ||
              tags.split('|').some(function (t) {
                return t.indexOf(key) >= 0 || key.indexOf(t) >= 0;
              });
            item.style.display = show ? '' : 'none';
          });
        });
      }
    }

    document.addEventListener('astro:page-load', function () {
      var list = document.getElementById('note-list');
      if (list) list.dataset.hydrated = '';
      boot();
    });
    boot();
  })();
</script>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  getAllProjects,
  getProjectBySlug,
  getPreviewHref,
  isPreviewExternal,
  getProjectPreviewUrl,
  getProjectServices,
  buildDeployUrl,
} from '../../data/projects';
import { getNoteBySlug } from '../../data/notes';
import { DEPLOY_HOST } from '../../data/deploy';
import { path } from '../../lib/paths';

export function getStaticPaths() {
  return getAllProjects().map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const project = getProjectBySlug(slug!);
if (!project) throw new Error(`Project not found: ${slug}`);

const previewHref = getPreviewHref(project);
const external = isPreviewExternal();
const liveUrl = getProjectPreviewUrl(project);
const services = getProjectServices(project);
const relatedNotes = project.relatedNoteSlugs
  .map((s) => getNoteBySlug(s))
  .filter(Boolean);
const toneBtn =
  project.coverTone === 'teal' ? 'teal' : project.coverTone === 'amber' ? 'amber' : '';
---

<BaseLayout current="projects" title={project.title} description={project.summary}>
  <main class="container page">
    <div class="hero">
      <div>
        <div class="crumb">
          <a href={path('/projects')}>项目</a>
          <span>/</span>
          <span>{project.slug}</span>
        </div>
        <div class="badge-row">
          <span class="live-dot"><i></i> Live on {DEPLOY_HOST}</span>
          {project.featured && <span class="tag tag-accent">Featured</span>}
          {project.tags.slice(0, 2).map((t) => <span class="tag">{t}</span>)}
          <span class="tag">{project.year}</span>
        </div>
        <h1 class="serif">{project.title}</h1>
        <p class="lead">{project.summary}</p>
        <div class="actions">
          <a
            class:list={['btn', 'btn-preview', toneBtn]}
            href={previewHref}
            target={external ? '_blank' : undefined}
            rel={external ? 'noopener noreferrer' : undefined}
          >
            <span class="play" aria-hidden="true">▶</span> 预览项目
          </a>
          {
            project.github && (
              <a class="btn btn-light" href={project.github} target="_blank" rel="noopener noreferrer">
                GitHub
              </a>
            )
          }
          {
            relatedNotes[0] && (
              <a class="btn btn-soft" href={path(`/notes/${relatedNotes[0]!.slug}`)}>
                相关笔记
              </a>
            )
          }
          <a class="btn btn-light" href={path('/projects')}>返回列表</a>
        </div>
      </div>

      <aside class="deploy-panel" aria-label="在线部署与预览">
        <div class:list={['head', project.coverTone]}>
          <div class="k">ONLINE DEPLOYMENT</div>
          <h2 class="serif">{external ? '在线预览入口' : '站内预览'}</h2>
          <p>
            服务器 IP · {DEPLOY_HOST} · {external ? '新标签打开' : '本站内嵌打开'}
          </p>
        </div>
        <div class="body">
          <div class="svc">
            {
              services.map((s) => (
                <div class="svc-item">
                  <div class="row1">
                    <span class="name">{s.name}</span>
                    <span class="port">:{s.port}</span>
                  </div>
                  {
                    external ? (
                      <a href={buildDeployUrl(s.port, s.path)} target="_blank" rel="noopener noreferrer">
                        {buildDeployUrl(s.port, s.path)}
                      </a>
                    ) : (
                      <span class="svc-url">{buildDeployUrl(s.port, s.path)}</span>
                    )
                  }
                </div>
              ))
            }
          </div>
          <div class="deploy-cta">
            <a
              class:list={['btn', 'btn-preview', toneBtn]}
              href={previewHref}
              target={external ? '_blank' : undefined}
              rel={external ? 'noopener noreferrer' : undefined}
            >
              <span class="play" aria-hidden="true">▶</span>
              {external ? '预览项目' : '打开站内预览'}
            </a>
            {
              !external && (
                <a class="btn btn-light" href={liveUrl} target="_blank" rel="noopener noreferrer" style="width:100%;margin-top:8px">
                  新标签打开
                </a>
              )
            }
          </div>
        </div>
      </aside>
    </div>

    <div class="preview-band">
      <div>
        <h3 class="serif">想直接看线上效果？</h3>
        <p>
          {
            external
              ? '主按钮将在新标签打开服务器部署实例。'
              : '进入站内预览页，以 iframe 内嵌部署实例（不新开窗口）。'
          }
        </p>
      </div>
      <a
        class:list={['btn', 'btn-preview', toneBtn]}
        href={previewHref}
        target={external ? '_blank' : undefined}
        rel={external ? 'noopener noreferrer' : undefined}
      >
        <span class="play" aria-hidden="true">▶</span> 预览项目
      </a>
    </div>

    <div class="content">
      <section class="block">
        <h2 class="serif">01 · 问题背景</h2>
        <p>{project.problem}</p>
      </section>
      <section class="block">
        <h2 class="serif">02 · 解决方案</h2>
        <p>{project.solution}</p>
        <pre class="arch">{`部署主机：${DEPLOY_HOST}
` + services.map((s) => `${s.name} :${s.port} → ${buildDeployUrl(s.port, s.path)}`).join('\n')}</pre>
      </section>
      <section class="block">
        <h2 class="serif">03 · 我的贡献</h2>
        <ul>
          {project.contributions.map((c) => <li>{c}</li>)}
        </ul>
      </section>
      <section class="block">
        <h2 class="serif">04 · 技术栈</h2>
        <div class="tags">
          {project.techStack.map((t) => <span class="tag">{t}</span>)}
        </div>
      </section>
      <section class="block">
        <h2 class="serif">05 · 成果与部署</h2>
        <div class="hl">
          {
            project.highlights.map((h) => (
              <div>
                <strong>{h.title}</strong>
                <span>{h.text}</span>
              </div>
            ))
          }
          {
            services.map((s) => (
              <div>
                <strong>
                  {s.name} · :{s.port}
                </strong>
                <span>{buildDeployUrl(s.port, s.path)}</span>
              </div>
            ))
          }
        </div>
      </section>
    </div>
  </main>
</BaseLayout>

<style>
  .page {
    padding-bottom: 40px;
  }
  .hero {
    padding: 36px 0 20px;
    display: grid;
    grid-template-columns: 1.15fr 0.95fr;
    gap: 22px;
    align-items: start;
  }
  .crumb {
    font-size: 13px;
    font-weight: 600;
    color: var(--muted);
    margin-bottom: 14px;
    display: flex;
    gap: 8px;
  }
  .crumb a {
    color: var(--accent);
  }
  .badge-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 14px;
  }
  h1 {
    font-size: clamp(32px, 4vw, 40px);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0 0 12px;
  }
  .lead {
    color: var(--ink-soft);
    font-size: 16.5px;
    font-weight: 500;
    max-width: 560px;
    margin: 0 0 20px;
    line-height: 1.7;
  }
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .play {
    display: inline-grid;
    place-items: center;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.22);
    font-size: 9px;
  }
  .deploy-panel {
    background: rgba(255, 255, 255, 0.94);
    border: 1px solid rgba(255, 255, 255, 0.85);
    border-radius: 22px;
    box-shadow: var(--shadow);
    overflow: hidden;
  }
  .head {
    padding: 16px 18px;
    color: #f5f5f4;
    background:
      radial-gradient(320px 100px at 0% 0%, rgba(91, 77, 255, 0.14), transparent 60%),
      #14131a;
  }
  .head.teal {
    background:
      radial-gradient(320px 100px at 0% 0%, rgba(20, 184, 166, 0.22), transparent 60%),
      #0c1f1c;
  }
  .head.amber {
    background:
      radial-gradient(320px 100px at 0% 0%, rgba(245, 158, 11, 0.22), transparent 60%),
      #1c140c;
  }
  .k {
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: 6px;
  }
  .head h2 {
    font-size: 20px;
    font-weight: 600;
    margin: 0 0 4px;
  }
  .head p {
    margin: 0;
    font-size: 12.5px;
    color: rgba(255, 255, 255, 0.55);
    font-weight: 500;
  }
  .body {
    padding: 16px 18px 18px;
  }
  .svc {
    display: grid;
    gap: 10px;
    margin-bottom: 14px;
  }
  .svc-item {
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 12px 14px;
    background: rgba(243, 241, 234, 0.45);
  }
  .row1 {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
  }
  .name {
    font-size: 13.5px;
    font-weight: 700;
  }
  .port {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    color: var(--accent);
    background: var(--accent-soft);
    border-radius: 999px;
    padding: 3px 8px;
  }
  .svc-item a,
  .svc-url {
    display: block;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-soft);
    font-weight: 500;
    word-break: break-all;
  }
  .svc-item a:hover {
    color: var(--accent);
  }
  .deploy-cta .btn {
    width: 100%;
  }
  .preview-band {
    margin: 8px 0 40px;
    padding: 20px 22px;
    border-radius: 20px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    background:
      radial-gradient(500px 140px at 0% 50%, rgba(91, 77, 255, 0.16), transparent 55%),
      rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(255, 255, 255, 0.85);
    box-shadow: var(--shadow-sm);
  }
  .preview-band h3 {
    margin: 0 0 4px;
    font-size: 20px;
    font-weight: 600;
  }
  .preview-band p {
    margin: 0;
    color: var(--muted);
    font-size: 13.5px;
    font-weight: 500;
  }
  .content {
    max-width: 820px;
    padding-bottom: 24px;
  }
  .block {
    margin-bottom: 28px;
  }
  .block h2 {
    font-size: 24px;
    font-weight: 600;
    margin: 0 0 12px;
  }
  .block p,
  .block li {
    color: var(--ink-soft);
    font-weight: 500;
  }
  .block ul {
    margin: 0;
    padding-left: 18px;
  }
  .block li + li {
    margin-top: 8px;
  }
  .arch {
    margin-top: 12px;
    background: rgba(20, 19, 26, 0.95);
    color: #d8d4ef;
    border-radius: 16px;
    padding: 18px 20px;
    font-family: var(--font-mono);
    font-size: 12.5px;
    line-height: 1.75;
    white-space: pre-wrap;
    overflow: auto;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .hl {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .hl div {
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 14px 16px;
  }
  .hl strong {
    display: block;
    margin-bottom: 6px;
  }
  .hl span {
    color: var(--muted);
    font-size: 13.5px;
    font-weight: 500;
    word-break: break-all;
  }
  @media (max-width: 900px) {
    .hero,
    .hl {
      grid-template-columns: 1fr;
    }
  }
</style>

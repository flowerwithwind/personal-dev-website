---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import {
  getAllProjects,
  getProjectBySlug,
  getProjectPreviewUrl,
  getProjectServices,
  buildDeployUrl,
} from '../../../data/projects';
import { DEPLOY_HOST, getPrimaryService } from '../../../data/deploy';
import { path } from '../../../lib/paths';

export function getStaticPaths() {
  return getAllProjects().map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const project = getProjectBySlug(slug!);
if (!project) throw new Error(`Project not found: ${slug}`);

const services = getProjectServices(project);
const primary = getPrimaryService(project.projectKey);
const defaultUrl = getProjectPreviewUrl(project);
const tone =
  project.coverTone === 'teal' ? 'teal' : project.coverTone === 'amber' ? 'amber' : 'violet';
---

<BaseLayout
  current="projects"
  title={`预览 · ${project.title}`}
  description={`站内预览 ${project.title}`}
>
  <div class="preview-page" data-animate="fade-up">
    <div class="toolbar container">
      <div class="left">
        <a class="back" href={path(`/projects/${project.slug}`)}>← 返回详情</a>
        <div class="titles">
          <h1 class="serif">{project.title}</h1>
          <p class="sub">站内预览 · 部署于 {DEPLOY_HOST}</p>
        </div>
      </div>
      <div class="right">
        <label class="svc-label">
          <span>服务</span>
          <select id="preview-service" data-default-url={defaultUrl}>
            {
              services.map((s) => {
                const url = buildDeployUrl(s.port, s.path);
                const selected = primary && s.port === primary.port && s.path === primary.path;
                return (
                  <option value={url} selected={selected}>
                    {s.name} · :{s.port}
                  </option>
                );
              })
            }
          </select>
        </label>
        <button type="button" class="btn btn-dark btn-sm" id="open-same-tab">本页打开演示</button>
        <a class="btn btn-light btn-sm" id="open-external" href={defaultUrl} target="_blank" rel="noopener noreferrer">
          新标签打开
        </a>
        <button type="button" class="btn btn-soft btn-sm" id="reload-frame">刷新</button>
      </div>
    </div>

    <div class="frame-shell container" id="preview-shell">
      <div class="chrome">
        <div class="dots" aria-hidden="true"><i></i><i></i><i></i></div>
        <div class="addr" id="preview-addr">{defaultUrl}</div>
        <span class:list={['badge', tone]} id="preview-badge">LIVE</span>
      </div>

      <div class="frame-wrap">
        <!-- iframe only used when embed is allowed (HTTPS→HTTPS or HTTP page→HTTP) -->
        <iframe
          id="preview-frame"
          title={`${project.title} 在线预览`}
          src="about:blank"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allow="clipboard-read; clipboard-write; fullscreen"
          hidden
        ></iframe>

        <div class="state" id="preview-state" aria-live="polite">
          <div class="state-card">
            <div class="state-icon" aria-hidden="true">🔒</div>
            <h2 class="serif" id="state-title">正在检测预览环境…</h2>
            <p id="state-desc">请稍候。</p>
            <div class="state-actions">
              <button type="button" class="btn btn-dark" id="state-same-tab">在本页打开演示站</button>
              <a class="btn btn-light" id="state-new-tab" href={defaultUrl} target="_blank" rel="noopener noreferrer">
                新标签打开
              </a>
            </div>
            <p class="state-tip" id="state-tip" hidden></p>
          </div>
        </div>
      </div>

      <p class="note" id="preview-note">
        说明：GitHub Pages 为 HTTPS。若演示站仍是 <code>http://</code>，浏览器会拦截 iframe 混合内容（Mixed Content），这不是你的项目挂了。新标签可打开是因为整页跳转到 HTTP。
      </p>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  (function () {
    function isHttpUrl(url) {
      return /^http:\/\//i.test(url || '');
    }
    function isHttpsPage() {
      return location.protocol === 'https:';
    }
    /** Browser blocks embedding HTTP frame inside HTTPS page */
    function isMixedContentBlocked(url) {
      return isHttpsPage() && isHttpUrl(url);
    }

    function boot() {
      var select = document.getElementById('preview-service');
      var frame = document.getElementById('preview-frame');
      var addr = document.getElementById('preview-addr');
      var openExt = document.getElementById('open-external');
      var openSame = document.getElementById('open-same-tab');
      var reload = document.getElementById('reload-frame');
      var state = document.getElementById('preview-state');
      var stateTitle = document.getElementById('state-title');
      var stateDesc = document.getElementById('state-desc');
      var stateTip = document.getElementById('state-tip');
      var stateSame = document.getElementById('state-same-tab');
      var stateNew = document.getElementById('state-new-tab');
      var badge = document.getElementById('preview-badge');
      if (!select || !frame || select.dataset.bound === '1') return;
      select.dataset.bound = '1';

      function currentUrl() {
        return select.value || select.getAttribute('data-default-url') || '';
      }

      function syncLinks(url) {
        if (addr) addr.textContent = url;
        if (openExt) openExt.setAttribute('href', url);
        if (stateNew) stateNew.setAttribute('href', url);
      }

      function showMixedContentUI(url) {
        frame.hidden = true;
        frame.removeAttribute('src');
        frame.src = 'about:blank';
        if (state) state.hidden = false;
        if (badge) {
          badge.textContent = '受限';
          badge.classList.add('warn');
        }
        if (stateTitle) stateTitle.textContent = '无法在 HTTPS 页面内嵌 HTTP 演示';
        if (stateDesc) {
          stateDesc.innerHTML =
            '个人站运行在 <strong>HTTPS</strong>（GitHub Pages），而演示地址是 <strong>HTTP</strong>（' +
            url +
            '）。浏览器安全策略会拦截这种 iframe，所以会一直「加载中」。项目本身可以正常访问。';
        }
        if (stateTip) {
          stateTip.hidden = false;
          stateTip.innerHTML =
            '可选解决：① 点下方「在本页打开演示站」（当前标签跳转到 HTTP，不是弹窗）② 给服务器配置 HTTPS 后即可真正内嵌。控制台里的 <code>chrome-extension://</code> 报错来自浏览器插件，可忽略。';
        }
      }

      function showEmbedUI(url) {
        if (state) state.hidden = true;
        if (badge) {
          badge.textContent = 'LIVE';
          badge.classList.remove('warn');
        }
        frame.hidden = false;
        if (state) {
          // brief loading overlay via state card when embedding
        }
        // show simple loading text overlay by reusing state briefly? keep iframe only
        frame.src = url;
      }

      function showBlockedEmbedUI(url) {
        // X-Frame-Options etc. — hard to detect reliably; user can switch
        frame.hidden = true;
        if (state) state.hidden = false;
        if (badge) {
          badge.textContent = '受限';
          badge.classList.add('warn');
        }
        if (stateTitle) stateTitle.textContent = '目标站可能禁止被嵌入';
        if (stateDesc) {
          stateDesc.textContent =
            '演示站可能设置了 X-Frame-Options / CSP，禁止被 iframe 嵌套。可用本页打开或新标签访问。';
        }
        if (stateTip) {
          stateTip.hidden = false;
          stateTip.textContent = '地址：' + url;
        }
      }

      function applyUrl(url) {
        if (!url) return;
        syncLinks(url);
        if (isMixedContentBlocked(url)) {
          showMixedContentUI(url);
          return;
        }
        showEmbedUI(url);
      }

      function goSameTab() {
        var url = currentUrl();
        if (url) location.assign(url);
      }

      select.addEventListener('change', function () {
        applyUrl(select.value);
      });

      if (reload) {
        reload.addEventListener('click', function () {
          applyUrl(currentUrl());
        });
      }
      if (openSame) openSame.addEventListener('click', goSameTab);
      if (stateSame) stateSame.addEventListener('click', goSameTab);

      // Initial
      applyUrl(currentUrl());
    }

    boot();
    document.addEventListener('astro:page-load', function () {
      var select = document.getElementById('preview-service');
      if (select) select.dataset.bound = '';
      boot();
    });
  })();
</script>

<style>
  .preview-page {
    padding: 20px 0 48px;
  }
  .toolbar {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 14px;
  }
  .left {
    display: grid;
    gap: 8px;
  }
  .back {
    color: var(--accent);
    font-size: 13.5px;
    font-weight: 700;
  }
  h1 {
    margin: 0;
    font-size: clamp(24px, 3vw, 30px);
    font-weight: 600;
  }
  .sub {
    margin: 4px 0 0;
    color: var(--muted);
    font-size: 13.5px;
    font-weight: 500;
  }
  .right {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: end;
  }
  .svc-label {
    display: grid;
    gap: 4px;
    font-size: 12px;
    font-weight: 600;
    color: var(--muted);
  }
  .svc-label select {
    min-height: 38px;
    border-radius: 999px;
    border: 1px solid var(--line-strong);
    background: #fff;
    padding: 0 14px;
    font: inherit;
    min-width: 180px;
  }
  .frame-shell {
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(255, 255, 255, 0.85);
    border-radius: 20px;
    box-shadow: var(--shadow);
    overflow: hidden;
    backdrop-filter: blur(10px);
  }
  .chrome {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--line);
    background: rgba(243, 241, 234, 0.75);
  }
  .dots {
    display: flex;
    gap: 6px;
  }
  .dots i {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #d1cdc4;
    display: block;
  }
  .dots i:nth-child(1) {
    background: #ff6b6b;
  }
  .dots i:nth-child(2) {
    background: #ffd166;
  }
  .dots i:nth-child(3) {
    background: #6bcb77;
  }
  .addr {
    flex: 1;
    min-width: 0;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-soft);
    background: rgba(255, 255, 255, 0.85);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 7px 12px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .badge {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.06em;
    color: #0f766e;
    background: rgba(15, 159, 138, 0.12);
    border-radius: 999px;
    padding: 4px 10px;
  }
  .badge.violet {
    color: #5b4dff;
    background: var(--accent-soft);
  }
  .badge.amber {
    color: #c2410c;
    background: rgba(234, 88, 12, 0.12);
  }
  .badge.warn {
    color: #b45309;
    background: rgba(245, 158, 11, 0.16);
  }
  .frame-wrap {
    position: relative;
    height: min(78vh, 860px);
    background:
      radial-gradient(600px 280px at 20% 10%, rgba(91, 77, 255, 0.08), transparent 55%),
      radial-gradient(500px 240px at 90% 80%, rgba(15, 159, 138, 0.08), transparent 50%),
      #f7f5ef;
  }
  iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
    background: #fff;
  }
  .state {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    padding: 24px;
    z-index: 2;
  }
  .state-card {
    width: min(100%, 520px);
    background: rgba(255, 255, 255, 0.96);
    border: 1px solid var(--line);
    border-radius: 20px;
    box-shadow: var(--shadow);
    padding: 28px 24px;
    text-align: center;
  }
  .state-icon {
    font-size: 28px;
    margin-bottom: 8px;
  }
  .state-card h2 {
    margin: 0 0 10px;
    font-size: 22px;
    font-weight: 600;
  }
  .state-card p {
    margin: 0 0 18px;
    color: var(--ink-soft);
    font-size: 14.5px;
    font-weight: 500;
    line-height: 1.65;
    text-align: left;
  }
  .state-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
    margin-bottom: 12px;
  }
  .state-tip {
    margin: 0;
    font-size: 12.5px;
    color: var(--muted);
    line-height: 1.6;
    text-align: left;
  }
  .state-tip code {
    font-family: var(--font-mono);
    font-size: 11px;
    background: rgba(12, 11, 16, 0.05);
    padding: 1px 5px;
    border-radius: 4px;
  }
  .note {
    margin: 0;
    padding: 12px 16px 14px;
    font-size: 12.5px;
    color: var(--muted);
    font-weight: 500;
    border-top: 1px solid var(--line);
    line-height: 1.55;
  }
  .note code {
    font-family: var(--font-mono);
    font-size: 11.5px;
  }
  @media (max-width: 860px) {
    .frame-wrap {
      height: 70vh;
    }
    .toolbar {
      align-items: stretch;
    }
  }
</style>
